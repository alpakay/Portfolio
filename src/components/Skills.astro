---
---
<section class="section section-skills" id="skills">
  <canvas class="game-canvas" data-game="tetris" data-pos="left" aria-hidden="true"></canvas>
  <canvas class="game-canvas" data-game="tetris" data-pos="right" aria-hidden="true"></canvas>

  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">
        <span class="eyebrow-num">03</span>
        <span data-l="tr">· Yetkinlikler</span>
        <span data-l="en">· Skills</span>
      </span>
      <h2 class="section-title">
        <span data-l="tr">Teknik profil</span>
        <span data-l="en">Technical profile</span>
      </h2>
    </div>

    <div class="skills-grid">
      <div class="skill-group reveal" data-delay="1">
        <div class="skill-group-title">Game Development</div>
        <ul class="skill-list">
          <li>Unity (2D &amp; 3D)</li>
          <li>Universal Render Pipeline</li>
          <li>ScriptableObjects</li>
          <li>Object Pooling</li>
          <li>
            <span data-l="tr">Prosedürel &amp; Physics sistemleri</span>
            <span data-l="en">Procedural &amp; Physics systems</span>
          </li>
        </ul>
      </div>

      <div class="skill-group reveal" data-delay="2">
        <div class="skill-group-title">Programming</div>
        <ul class="skill-list">
          <li>C#</li>
          <li>Object-Oriented Programming</li>
          <li>Data Structures &amp; Algorithms</li>
          <li>
            <span data-l="tr">Clean Architecture prensipleri</span>
            <span data-l="en">Clean Architecture principles</span>
          </li>
        </ul>
      </div>

      <div class="skill-group reveal" data-delay="3">
        <div class="skill-group-title">
          <span data-l="tr">Performans</span>
          <span data-l="en">Performance</span>
        </div>
        <ul class="skill-list">
          <li>
            <span data-l="tr">Memory &amp; GC optimizasyonu</span>
            <span data-l="en">Memory &amp; GC optimization</span>
          </li>
          <li>Unity Profiler</li>
          <li>Allocation Reduction</li>
          <li>Runtime Performance Tuning</li>
        </ul>
      </div>

      <div class="skill-group reveal" data-delay="1">
        <div class="skill-group-title">Backend &amp; Web</div>
        <ul class="skill-list">
          <li>ASP.NET Core MVC</li>
          <li>Entity Framework Core</li>
          <li>REST API</li>
          <li>SQL Server</li>
        </ul>
      </div>

      <div class="skill-group reveal" data-delay="2">
        <div class="skill-group-title">Tools &amp; Workflow</div>
        <ul class="skill-list">
          <li>Git &amp; GitHub</li>
          <li>Google Play Console</li>
          <li>Android Build Pipeline</li>
          <li>
            <span data-l="tr">AI Destekli Geliştirme</span>
            <span data-l="en">AI-Assisted Development</span>
          </li>
        </ul>
      </div>

      <div class="skill-group reveal" data-delay="3">
        <div class="skill-group-title">
          <span data-l="tr">Diller</span>
          <span data-l="en">Languages</span>
        </div>
        <ul class="skill-list">
          <li>
            <span data-l="tr">Türkçe — Ana Dil</span>
            <span data-l="en">Turkish — Native</span>
          </li>
          <li>
            <span data-l="tr">İngilizce — B2</span>
            <span data-l="en">English — B2</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
