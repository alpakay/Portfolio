---
import Icons from './Icons.astro';
---
<section class="section" id="contact">
  <div class="container contact-inner">
    <div class="reveal">
      <span class="section-tag">
        <span data-l="tr">05 — İletişim</span>
        <span data-l="en">05 — Contact</span>
      </span>
      <h2 class="contact-title">
        <span data-l="tr">Birlikte çalışalım.</span>
        <span data-l="en">Let's work together.</span>
      </h2>
      <p class="contact-subtitle">
        <span data-l="tr">Yeni fırsatlara ve iş birliklerine açığım.</span>
        <span data-l="en">Open to new opportunities and collaborations.</span>
      </p>
    </div>

    <div class="contact-grid reveal" data-delay="1">
      <a href="mailto:ahmeta3557@gmail.com" class="contact-card">
        <Icons name="mail" size={22} />
        <span class="contact-label">Email</span>
        <span class="contact-value">ahmeta3557@gmail.com</span>
      </a>

      <a href="https://github.com/alpakay" target="_blank" rel="noopener" class="contact-card">
        <Icons name="github" size={22} />
        <span class="contact-label">GitHub</span>
        <span class="contact-value">github.com/alpakay</span>
      </a>

      <a href="https://linkedin.com/in/pakay7" target="_blank" rel="noopener" class="contact-card">
        <Icons name="linkedin" size={22} />
        <span class="contact-label">LinkedIn</span>
        <span class="contact-value">linkedin.com/in/pakay7</span>
      </a>

      <a href="https://pakay.itch.io" target="_blank" rel="noopener" class="contact-card">
        <Icons name="itch" size={22} />
        <span class="contact-label">Itch.io</span>
        <span class="contact-value">pakay.itch.io</span>
      </a>

      <div class="contact-card" style="cursor: default;">
        <Icons name="pin" size={22} />
        <span class="contact-label">
          <span data-l="tr">Konum</span>
          <span data-l="en">Location</span>
        </span>
        <span class="contact-value">
          <span data-l="tr">Çiğli / İzmir, Türkiye</span>
          <span data-l="en">Çiğli / İzmir, Türkiye</span>
        </span>
      </div>
    </div>
  </div>
</section>
